{
  "name": "@fisker/eslint-config",
  "version": "16.0.0",
  "description": "fisker's Shareable ESLint Configuration",
  "keywords": [
    "config",
    "eslint",
    "fisker"
  ],
  "homepage": "https://github.com/fisker/shared-configs#readme",
  "bugs": {
    "url": "https://github.com/fisker/shared-configs/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/fisker/shared-configs.git"
  },
  "license": "MIT",
  "author": "fisker Cheung <lionkay@gmail.com> (https://www.fiskercheung.com/)",
  "type": "module",
  "exports": {
    ".": "./index.js",
    "./*": "./*"
  },
  "files": [
    "index.js",
    "plugins",
    "ignores"
  ],
  "scripts": {
    "inspect": "eslint-config-inspector --config index.js",
    "test": "ava"
  },
  "ava": {
    "timeout": "2m",
    "verbose": true
  },
  "dependencies": {
    "@babel/core": "8.0.1",
    "@babel/eslint-parser": "8.0.1",
    "@eslint-community/eslint-plugin-eslint-comments": "4.7.2",
    "@eslint/js": "10.0.1",
    "@stylistic/eslint-plugin": "5.10.0",
    "eslint-config-prettier": "10.1.8",
    "eslint-plugin-es-x": "10.0.0",
    "eslint-plugin-n": "18.2.2",
    "eslint-plugin-promise": "7.3.0",
    "eslint-plugin-regexp": "3.1.1",
    "eslint-plugin-simple-import-sort": "14.0.0",
    "eslint-plugin-sonarjs": "4.2.0",
    "eslint-plugin-sort-class-members": "1.22.1",
    "eslint-plugin-unicorn": "65.0.1",
    "globals": "17.7.0"
  },
  "devDependencies": {
    "@eslint/config-inspector": "3.1.0",
    "ava": "8.0.1"
  },
  "peerDependencies": {
    "eslint": "*",
    "prettier": "*"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "gitHead": "21a03bf2f96f10cd8fe7f602d9f4008ca0ee5b2d"
}
